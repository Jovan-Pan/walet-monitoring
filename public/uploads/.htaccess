# Disable PHP execution in uploads folder (P0-3 security fix)
# This prevents uploaded files (even if .php) from being executed

# Apache 2.4+
<IfModule mod_authz_core.c>
    Require all granted
</IfModule>

# Disable script execution
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# Block direct access to PHP files
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|phps|cgi|pl|py|sh|jsp|asp|aspx)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Allow only safe file types
<FilesMatch "\.(jpg|jpeg|png|gif|pdf|webp)$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Allow from all
    </IfModule>
</FilesMatch>

# Prevent directory listing
Options -Indexes

# Prevent hotlinking (optional)
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Block suspicious file types
    RewriteRule \.(php|phtml|php3|php4|php5|php7|phps|cgi|pl|py|sh|jsp|asp|aspx)$ - [F,L,NC]
</IfModule>
