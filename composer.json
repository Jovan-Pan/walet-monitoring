{
    "name": "walet/walet-monitoring",
    "type": "project",
    "description": "Sistem Informasi Monitoring Produksi Sarang Burung Walet - CodeIgniter 4",
    "homepage": "https://codeigniter.com",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "4.4.8",
        "tecnickcom/tcpdf": "^6.6",
        "phpoffice/phpspreadsheet": "^1.29"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "post-update-cmd": [
            "CodeIgniter\\Composer\\Scripts::postUpdate"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "policy": {
            "advisories": {
                "block": false
            }
        }
    }
}
